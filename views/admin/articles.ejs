<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
</head>
<body class="admin-body">
<div class="admin-layout">
    <%- include('../partials/admin-sidebar') %>
    <main class="admin-main">
        <div class="admin-topbar">
            <h1>Articles</h1>
            <a href="/admin/articles/add" class="btn btn-primary btn-sm"><i class="fas fa-plus"></i> Add Article</a>
        </div>
        <%- include('../partials/flash') %>
        <div class="admin-table-wrapper">
            <% if (articles.length === 0) { %>
                <div class="empty-state"><i class="fas fa-newspaper"></i><p>No articles yet. <a href="/admin/articles/add">Add one</a>.</p></div>
            <% } else { %>
            <div class="table-scroll">
                <table class="admin-table">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Title</th>
                            <th>Category</th>
                            <th>Author</th>
                            <th>Featured</th>
                            <th>Date</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% articles.forEach((article, i) => { %>
                        <tr>
                            <td><%= i + 1 %></td>
                            <td><strong><%= article.title.substring(0, 50) %><%= article.title.length > 50 ? '...' : '' %></strong></td>
                            <td><%= article.category %></td>
                            <td><%= article.author %></td>
                            <td>
                                <% if (article.is_featured) { %>
                                    <span class="badge badge-new">Yes</span>
                                <% } else { %>
                                    <span class="badge badge-read">No</span>
                                <% } %>
                            </td>
                            <td><%= new Date(article.created_at).toLocaleDateString() %></td>
                            <td class="action-btns">
                                <a href="/admin/articles/<%= article.id %>/edit" class="btn-icon edit" title="Edit"><i class="fas fa-edit"></i></a>
                                <form action="/admin/articles/<%= article.id %>/delete" method="POST" style="display:inline" onsubmit="return confirm('Delete this article?')">
                                    <button type="submit" class="btn-icon delete" title="Delete"><i class="fas fa-trash"></i></button>
                                </form>
                            </td>
                        </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
            <% } %>
        </div>
    </main>
</div>
</body>
</html>