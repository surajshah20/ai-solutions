<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= title %>
    </title>
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
</head>

<body class="admin-body">

    <div class="admin-layout">
        <!-- Sidebar -->
        <%- include('../partials/admin-sidebar') %>

        <!-- Main Content -->
        <main class="admin-main">
            <div class="admin-topbar">
                <h1>Dashboard</h1>
                <span class="admin-date">
                    <%= new Date().toDateString() %>
                </span>
            </div>

            <%- include('../partials/flash') %>

                <!-- Stats Cards -->
                <div class="admin-stats" style="grid-template-columns: repeat(4, 1fr);">
                    <div class="admin-stat-card blue">
                        <div class="stat-icon"><i class="fas fa-envelope"></i></div>
                        <div class="stat-info">
                            <span class="stat-num">
                                <%= total %>
                            </span>
                            <span class="stat-lbl">Total Inquiries</span>
                        </div>
                    </div>
                    <div class="admin-stat-card green">
                        <div class="stat-icon"><i class="fas fa-bell"></i></div>
                        <div class="stat-info">
                            <span class="stat-num">
                                <%= newCount %>
                            </span>
                            <span class="stat-lbl">New Inquiries</span>
                        </div>
                    </div>
                    <div class="admin-stat-card grey">
                        <div class="stat-icon"><i class="fas fa-check"></i></div>
                        <div class="stat-info">
                            <span class="stat-num">
                                <%= readCount %>
                            </span>
                            <span class="stat-lbl">Read</span>
                        </div>
                    </div>
                    <div class="admin-stat-card blue">
                        <div class="stat-icon"><i class="fas fa-star"></i></div>
                        <div class="stat-info">
                            <span class="stat-num">
                                <%= feedbackCount %>
                            </span>
                            <span class="stat-lbl">Feedback</span>
                        </div>
                    </div>
                </div>

                <!-- Inquiries Table -->
                <div class="admin-table-wrapper">
                    <div class="table-header">
                        <h2>Customer Inquiries</h2>
                        <input type="text" id="searchInput" placeholder="Search inquiries..." oninput="filterTable()">
                    </div>

                    <% if (inquiries.length===0) { %>
                        <div class="empty-state">
                            <i class="fas fa-inbox"></i>
                            <p>No inquiries yet.</p>
                        </div>
                        <% } else { %>
                            <div class="table-scroll">
                                <table class="admin-table" id="inquiriesTable">
                                    <thead>
                                        <tr>
                                            <th>#</th>
                                            <th>Name</th>
                                            <th>Email</th>
                                            <th>Company</th>
                                            <th>Country</th>
                                            <th>Status</th>
                                            <th>Date</th>
                                            <th>Actions</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <% inquiries.forEach((inq, i)=> { %>
                                            <tr>
                                                <td>
                                                    <%= i + 1 %>
                                                </td>
                                                <td><strong>
                                                        <%= inq.name %>
                                                    </strong></td>
                                                <td>
                                                    <%= inq.email %>
                                                </td>
                                                <td>
                                                    <%= inq.company_name %>
                                                </td>
                                                <td>
                                                    <%= inq.country %>
                                                </td>
                                                <td>
                                                    <span class="badge badge-<%= inq.status %>">
                                                        <%= inq.status.charAt(0).toUpperCase() + inq.status.slice(1) %>
                                                    </span>
                                                </td>
                                                <td>
                                                    <%= new Date(inq.created_at).toLocaleDateString() %>
                                                </td>
                                                <td class="action-btns">
                                                    <a href="/admin/inquiry/<%= inq.id %>" class="btn-icon view"
                                                        title="View">
                                                        <i class="fas fa-eye"></i>
                                                    </a>
                                                    <a href="/admin/inquiry/<%= inq.id %>/edit" class="btn-icon edit"
                                                        title="Edit">
                                                        <i class="fas fa-edit"></i>
                                                    </a>
                                                    <form action="/admin/inquiry/<%= inq.id %>/delete" method="POST"
                                                        style="display:inline"
                                                        onsubmit="return confirm('Delete this inquiry?')">
                                                        <button type="submit" class="btn-icon delete" title="Delete">
                                                            <i class="fas fa-trash"></i>
                                                        </button>
                                                    </form>
                                                </td>
                                            </tr>
                                            <% }) %>
                                    </tbody>
                                </table>
                            </div>
                            <% } %>
                </div>
        </main>
    </div>

    <script>
        function filterTable() {
            const input = document.getElementById('searchInput').value.toLowerCase();
            const rows = document.querySelectorAll('#inquiriesTable tbody tr');
            rows.forEach(row => {
                row.style.display = row.textContent.toLowerCase().includes(input) ? '' : 'none';
            });
        }
    </script>
</body>

</html>