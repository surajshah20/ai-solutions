<%- include('partials/header') %>

<section class="page-hero">
    <div class="container">
        <h1>Latest <span class="highlight">Articles</span></h1>
        <p>Insights, updates and thought leadership from the AI-Solutions team</p>
    </div>
</section>

<section class="articles-section">
    <div class="container">
        <% if (articles.length === 0) { %>
            <div class="empty-state" style="text-align:center;padding:60px">
                <i class="fas fa-newspaper" style="font-size:3rem;opacity:0.3;display:block;margin-bottom:12px"></i>
                <p>No articles published yet. Check back soon!</p>
            </div>
        <% } else { %>
            <% const featured = articles.find(a => a.is_featured); %>
            <% const rest = articles.filter(a => !a.is_featured); %>

            <% if (featured) { %>
            <div class="article-featured">
                <div class="article-featured-badge">Featured</div>
                <span class="article-category"><%= featured.category %></span>
                <h2><%= featured.title %></h2>
                <p><%= featured.content.substring(0, 350) %>...</p>
                <div class="article-meta">
                    <span><i class="fas fa-user"></i> <%= featured.author %></span>
                    <span><i class="fas fa-calendar"></i> <%= new Date(featured.created_at).toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' }) %></span>
                </div>
            </div>
            <% } %>

            <% if (rest.length > 0) { %>
            <div class="articles-grid">
                <% rest.forEach(article => { %>
                <div class="article-card">
                    <div class="article-card-img">
                        <div class="article-img-placeholder"><i class="fas fa-newspaper"></i></div>
                    </div>
                    <div class="article-card-body">
                        <span class="article-category"><%= article.category %></span>
                        <h3><%= article.title %></h3>
                        <p><%= article.content.substring(0, 120) %>...</p>
                        <div class="article-meta">
                            <span><i class="fas fa-user"></i> <%= article.author %></span>
                            <span><i class="fas fa-calendar"></i> <%= new Date(article.created_at).toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' }) %></span>
                        </div>
                    </div>
                </div>
                <% }) %>
            </div>
            <% } %>
        <% } %>
    </div>
</section>

<section class="cta-section">
    <div class="container">
        <h2>Want to Learn More?</h2>
        <p>Speak to our team about how AI-Solutions can help your business.</p>
        <a href="/contact" class="btn btn-white">Contact Us</a>
    </div>
</section>

<%- include('partials/footer') %>